.container { padding: 30rpx; background: #f8fafc; min-height: 100vh; }
.card { background: #fff; border-radius: 28rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); }
.h1 { font-size: 32rpx; font-weight: bold; margin-bottom: 20rpx; }

/* 映射组件样式 */
.mapping-section { background: #f1f5f9; padding: 20rpx; border-radius: 16rpx; margin-top: 20rpx; }
.mapping-item { background: #fff; padding: 20rpx; border-radius: 12rpx; margin-bottom: 20rpx; border: 1rpx solid #e2e8f0; }
.mapping-row { display: flex; align-items: center; margin-bottom: 10rpx; font-size: 24rpx; }
.map-icon { color: #64748b; margin: 0 10rpx; flex-shrink: 0; }
.small-picker { background: #f8fafc; border: 1rpx solid #cbd5e1; padding: 8rpx 16rpx; border-radius: 8rpx; max-width: 250rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.small-picker.active { color: #3b82f6; border-color: #3b82f6; font-weight: bold; }
.del-btn { color: #ef4444; font-size: 32rpx; margin-left: auto; padding: 0 10rpx; }
.add-mapping-btn { background: #fff; color: #3b82f6; font-size: 24rpx; border: 1rpx dashed #3b82f6; margin-top: 10rpx; }

.picker-box { background: #f8fafc; border: 1rpx solid #e2e8f0; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; color: #1e293b; }
.label { font-size: 26rpx; font-weight: bold; color: #475569; margin-bottom: 12rpx; display: block; }
.form-item { margin-bottom: 30rpx; }

/* 其他样式继承之前的... */
.btn-primary { background: #3b82f6; color: #fff; font-weight: bold; }
.btn-next { background: #10b981; color: #fff; }
.step-indicator { display: flex; align-items: center; justify-content: center; padding: 20rpx 0; }
.node { width: 60rpx; height: 30rpx; background: #cbd5e1; border-radius: 15rpx; font-size: 18rpx; color: #fff; text-align: center; }
.node.on { background: #3b82f6; }
.line { flex: 1; height: 2rpx; background: #cbd5e1; margin: 0 10rpx; }