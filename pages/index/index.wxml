<view class="container">
  <view class="header-zone">
    <view class="mode-badge">{{modeName}}</view>
    <scroll-view scroll-x class="lifecycle-tabs" wx:if="{{mode === 'teach'}}">
      <view class="tab-item {{lifecycle === 'pre' ? 'active' : ''}}" bindtap="setLifecycle" data-val="pre">1.课前准备</view>
      <view class="tab-item {{lifecycle === 'in' ? 'active' : ''}}" bindtap="setLifecycle" data-val="in">2.课中互动</view>
      <view class="tab-item {{lifecycle === 'post' ? 'active' : ''}}" bindtap="setLifecycle" data-val="post">3.分层作业</view>
      <view class="tab-item {{lifecycle === 'reflect' ? 'active' : ''}}" bindtap="setLifecycle" data-val="reflect">4.教学反思</view>
    </scroll-view>
  </view>

  <view class="guide-card">
    <view class="guide-title">💡 {{guideInfo.title}}</view>
    <view class="guide-item text-blue">{{guideInfo.inputHint}}</view>
    <view class="guide-item text-green">{{guideInfo.outputHint}}</view>
  </view>

  <view class="step-title">Step 1: 提供素材</view>
  <view class="workspace-card">
    <view class="action-bar" wx:if="{{lifecycle !== 'reflect'}}">
      <button class="cam-btn" bindtap="chooseImage" loading="{{loadingState === 1}}">📷 连拍多页/手写识别</button>
      <text class="page-counter" wx:if="{{pageCount > 0}}">已提取 {{pageCount}} 页</text>
    </view>
    <textarea class="content-editor" value="{{textContent}}" bindinput="onInput" maxlength="-1" placeholder="{{guideInfo.placeholder}}" />
    <view class="editor-footer">
      <text class="word-count">{{textContent.length}} 字</text>
      <text class="clear-btn" bindtap="clearAll">清空重录</text>
    </view>
  </view>

  <view class="step-title">Step 2: AI 智能处理</view>
  <button class="magic-btn {{loadingState === 2 ? 'is-loading' : ''}}" bindtap="doAI" disabled="{{!textContent || loadingState !== 0}}">
    <text wx:if="{{loadingState === 0}}">🚀 {{actionName}}</text>
    <text wx:else>DeepSeek 正在深度处理中...</text>
  </button>

  <view class="result-card" wx:if="{{result}}">
    <view class="res-header">
      <text class="res-title">📊 成果报告</text>
      <view class="btn-group">
        <button class="sync-btn" size="mini" bindtap="exportToDocs">同步至电脑</button>
        <button class="share-btn" size="mini" open-type="share">转发</button>
      </view>
    </view>
    <scroll-view scroll-y class="res-scroll">
      <text user-select class="res-text">{{result}}</text>
    </scroll-view>
  </view>
  <view class="bottom-space"></view>
</view>