page {
  background-color: #f4f5f7;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.container {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 顶部上传区 */
.upload-section {
  width: 100%;
  height: 350rpx;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 4rpx dashed #d1d5db;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-camera {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.tips-main {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.tips-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* AI 处理动画 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  color: #666;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #00bcd4;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 结果列表区 */
.result-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-bottom: 120rpx; /* 为底部悬浮栏留出空间 */
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
}

.question-list {
  flex: 1;
  height: 100%;
}

.q-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.q-card.selected {
  border-color: #00bcd4;
  background-color: #f2fcfe;
}

.q-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.q-type {
  font-size: 24rpx;
  color: #fff;
  background-color: #00bcd4;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.q-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #00bcd4;
  background-color: rgba(0, 188, 212, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
}

.q-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap; /* 保持题目原本的换行格式 */
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.stat {
  font-size: 30rpx;
  color: #333;
}

.highlight {
  color: #00bcd4;
  font-weight: bold;
  font-size: 36rpx;
  margin: 0 10rpx;
}

.export-btn {
  background-color: #00bcd4;
  color: #fff;
  font-size: 30rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  margin: 0;
}

.export-btn.disabled {
  background-color: #ccc;
}