page { background: #f4f5f7; height: 100%; }
.login-wrapper { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; }
.login-card { width: 100%; background: #fff; border-radius: 32rpx; padding: 80rpx 50rpx; text-align: center; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.04); }
.logo-box { font-size: 110rpx; margin-bottom: 24rpx; }
.title { font-size: 44rpx; font-weight: 800; color: #1f2937; display: block; margin-bottom: 12rpx; }
.subtitle { font-size: 26rpx; color: #6b7280; display: block; margin-bottom: 60rpx; }
.pwd-input { background: #f3f4f6; height: 100rpx; border-radius: 20rpx; font-size: 36rpx; letter-spacing: 16rpx; text-align: center; margin-bottom: 40rpx; color: #1f2937; font-weight: bold; }
.login-btn { background: #2563eb; color: #fff; border-radius: 20rpx; height: 96rpx; line-height: 96rpx; font-size: 32rpx; font-weight: bold; width: 100% !important; }
.footer-text { margin-top: 60rpx; font-size: 22rpx; color: #9ca3af; }